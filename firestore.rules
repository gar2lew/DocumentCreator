rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userOrgId() {
      return userDoc().organisationId;
    }

    function userRole() {
      return userDoc().role;
    }

    function isEditorOrAbove() {
      return userRole() in ['admin', 'editor'];
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /organisations/{orgId} {
      allow read, write: if isAuthenticated();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userOrgId() == request.resource.data.organisationId && isEditorOrAbove();
      allow update: if isAuthenticated() && userOrgId() == resource.data.organisationId && request.resource.data.organisationId == resource.data.organisationId && isEditorOrAbove();
      allow delete: if isAuthenticated() && userOrgId() == resource.data.organisationId && isAdmin();
    }

    match /deals/{dealId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userOrgId() == request.resource.data.organisationId && isEditorOrAbove();
      allow update: if isAuthenticated() && userOrgId() == resource.data.organisationId && request.resource.data.organisationId == resource.data.organisationId && isEditorOrAbove();
      allow delete: if isAuthenticated() && userOrgId() == resource.data.organisationId && isAdmin();
    }

    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userOrgId() == request.resource.data.organisationId && isEditorOrAbove();
      allow update: if isAuthenticated() && userOrgId() == resource.data.organisationId && request.resource.data.organisationId == resource.data.organisationId && (isEditorOrAbove() && resource.data.locked != true || isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['locked', 'updatedAt']));
      allow delete: if isAuthenticated() && userOrgId() == resource.data.organisationId && isAdmin();
    }

    match /template_versions/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userOrgId() == request.resource.data.organisationId && isEditorOrAbove();
      allow update: if false;
      allow delete: if false;
    }

    match /documents_generated/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userOrgId() == request.resource.data.organisationId;
      allow update: if isAuthenticated() && userOrgId() == resource.data.organisationId && request.resource.data.organisationId == resource.data.organisationId;
      allow delete: if false;
    }
  }
}
